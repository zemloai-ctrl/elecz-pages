# Cloudflare Pages _redirects
# Static pages are served by CF Pages
# All API and MCP traffic is proxied to Render backend

# Clean URL routing (HTML files without extension)
/docs           /docs.html      200
/privacy        /privacy.html   200
/terms          /terms.html     200

# API proxy → Render backend
# Replace elecz-api.onrender.com with your actual Render URL
/signal/*       https://elecz-api.onrender.com/signal/:splat  200
/mcp/*          https://elecz-api.onrender.com/mcp/:splat     200
/mcp            https://elecz-api.onrender.com/mcp            200
/go/*           https://elecz-api.onrender.com/go/:splat      200
/health         https://elecz-api.onrender.com/health         200
/openapi.json   https://elecz-api.onrender.com/openapi.json   200
/sitemap.xml    https://elecz-api.onrender.com/sitemap.xml    200
/robots.txt     https://elecz-api.onrender.com/robots.txt     200
/.well-known/*  https://elecz-api.onrender.com/.well-known/:splat  200
/favicon.svg    https://elecz-api.onrender.com/favicon.svg    200
/favicon.ico    https://elecz-api.onrender.com/favicon.ico    200
